
{
  "version": 2,
  "crons": [
    {
      "path": "/api/wallet-connect/daily-report",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/referral/snapshot-cron",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
