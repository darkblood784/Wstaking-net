# ============================================
# WSTAKING PRE-PRODUCTION ENVIRONMENT
# ============================================
# Copy this to .env.preprod and fill with preprod values
# NEVER commit actual credentials to public repos
# Use GitHub Secrets or environment variable injection for CI/CD

# ============================================
# FRONTEND CONFIG
# ============================================

VITE_WALLET_CONNECT_ID=your_preprod_wallet_connect_project_id

# Firebase (Use preprod Firebase project)
VITE_FIREBASE_API_KEY=YOUR_PREPROD_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=wstaking-preprod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=wstaking-preprod
VITE_FIREBASE_STORAGE_BUCKET=wstaking-preprod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PREPROD_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_PREPROD_APP_ID

# Use testnet RPC endpoints for preprod
VITE_BASE_RPC=https://sepolia.base.org
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_BSC_RPC=https://data-seed-prebsc-1-1.bnbchain.org:8545
VITE_BSC_TESTNET_RPC=https://data-seed-prebsc-1-1.bnbchain.org:8545
VITE_XLAYER_RPC=https://testrpc.xlayer.tech
VITE_XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech

# ============================================
# BACKEND CONFIG
# ============================================

PORT=3000
NODE_ENV=production

# Firebase Admin (use preprod service account)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Admin secret (generate new for preprod)
ADMIN_AUTH_SECRET=your_preprod_secret_min_32_chars

# ============================================
# TESTNET CONTRACT ADDRESSES
# ============================================

# BASE Sepolia (testnet)
BASE_MAINNET_STAKING_ADDRESS=0x_testnet_address
BASE_SEPOLIA_STAKING_ADDRESS=0x_testnet_address

# BSC Testnet
BSC_MAINNET_STAKING_ADDRESS=0x_testnet_address
BSC_TESTNET_STAKING_ADDRESS=0x_testnet_address

# XLayer Testnet
XLAYER_MAINNET_STAKING_ADDRESS=0x_testnet_address

# ============================================
# PREPROD EMAIL
# ============================================

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=preprod-staking@example.com
SMTP_PASSWORD=your_preprod_smtp_password

EMAIL_FROM=preprod-noreply@wstaking.net
EMAIL_FROM_NAME=WStaking Preprod

# ============================================
# API KEYS
# ============================================

ETHERSCAN_API_KEY=your_preprod_etherscan_api_key
COINGECKO_API_KEY=your_coingecko_api_key
BSCSCAN_API_KEY=your_preprod_bscscan_api_key

# ============================================
# CORS
# ============================================

# Allow preprod domain and localhost for testing
CORS_ALLOWED_ORIGINS=https://preprod.wstaking.net,http://localhost:5173,http://localhost:3000

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info

# ============================================
# FEATURE FLAGS (for testing)
# ============================================

FEATURE_ADMIN_PANEL=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_ANALYTICS=true
