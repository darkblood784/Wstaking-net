# ============================================
# WSTAKING PRODUCTION ENVIRONMENT
# ============================================
# CRITICAL: NEVER commit actual credentials to public repos
# 
# Setup Guide:
# 1. Use GitHub Secrets for sensitive values
# 2. Use environment variable injection in deployment
# 3. Use dedicated secrets management service (AWS Secrets Manager, etc.)
# 4. Rotate credentials regularly
# 5. Audit access logs

# ============================================
# FRONTEND CONFIG
# ============================================

# Production Wallet Connect Project
VITE_WALLET_CONNECT_ID=your_production_wallet_connect_project_id

# Production Firebase Project
VITE_FIREBASE_API_KEY=YOUR_PRODUCTION_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=wstaking.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=wstaking-prod
VITE_FIREBASE_STORAGE_BUCKET=wstaking.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PRODUCTION_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_PRODUCTION_APP_ID

# Production RPC endpoints
# Use high-reliability endpoints: Infura Premium, Alchemy, or QuickNode
VITE_BASE_RPC=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_BSC_RPC=https://bsc-dataseed.binance.org
VITE_BSC_TESTNET_RPC=https://data-seed-prebsc-1-1.bnbchain.org:8545
VITE_XLAYER_RPC=https://rpc.xlayer.tech
VITE_XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech

# ============================================
# BACKEND CONFIG - PRODUCTION ONLY
# ============================================

PORT=3000
NODE_ENV=production

# Firebase Admin SDK - Use GitHub Secrets or hosted secrets service
# Set via: export FIREBASE_SERVICE_ACCOUNT_JSON="$(cat /path/to/service-account.json)"
FIREBASE_SERVICE_ACCOUNT_JSON=

# Production Admin Secret
# Generate: openssl rand -hex 32
# Store in: GitHub Secrets, AWS Secrets Manager, or HashiCorp Vault
# CRITICAL: Use a strong, randomly generated value
ADMIN_AUTH_SECRET=

# ============================================
# PRODUCTION MAINNET CONTRACTS
# ============================================

# BASE Mainnet
BASE_MAINNET_STAKING_ADDRESS=0x

# BASE Sepolia (for testnet operations if needed)
BASE_SEPOLIA_STAKING_ADDRESS=0x

# BSC Mainnet
BSC_MAINNET_STAKING_ADDRESS=0x

# BSC Testnet (for cross-chain testing)
BSC_TESTNET_STAKING_ADDRESS=0x

# XLayer Mainnet
XLAYER_MAINNET_STAKING_ADDRESS=0x

# ============================================
# PRODUCTION EMAIL
# ============================================

# Use enterprise email service (Office365, SendGrid, AWS SES)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=

# Use application-specific password, not account password
SMTP_PASSWORD=

EMAIL_FROM=noreply@wstaking.net
EMAIL_FROM_NAME=WStaking

# ============================================
# PRODUCTION API KEYS
# ============================================

# Etherscan (for mainnet contract verification)
ETHERSCAN_API_KEY=

# CoinGecko API
COINGECKO_API_KEY=

# BSCScan
BSCSCAN_API_KEY=

# ============================================
# PRODUCTION CORS
# ============================================

# Only allow production domains
CORS_ALLOWED_ORIGINS=https://wstaking.net,https://www.wstaking.net

# ============================================
# PRODUCTION LOGGING
# ============================================

# Set to 'warn' or 'error' in production to reduce noise
LOG_LEVEL=info

# ============================================
# PRODUCTION MONITORING
# ============================================

# Optional: Sentry for error tracking
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# Optional: Datadog for monitoring
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features in production
FEATURE_ADMIN_PANEL=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_ANALYTICS=true

# ============================================
# PRODUCTION SECURITY CHECKLIST
# ============================================

# Before deploying to production:
# 
# ✅ All credentials stored in secrets management (not in source code)
# ✅ HTTPS enforced for all traffic
# ✅ CORS origins restricted to production domains only
# ✅ Database backups configured and tested
# ✅ Monitoring and alerting set up (Sentry, DataDog, etc.)
# ✅ Rate limiting configured on API endpoints
# ✅ DDoS protection enabled (Cloudflare, AWS Shield)
# ✅ Web Application Firewall (WAF) configured
# ✅ SSL/TLS certificates valid and auto-renewing
# ✅ API keys rotated regularly
# ✅ Audit logs enabled and monitored
# ✅ Incident response plan documented
# ✅ Disaster recovery plan tested

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================

# GitHub Actions Setup:
# 1. Create GitHub Secrets for each variable:
#    Settings → Secrets and Variables → Actions → New repository secret
# 2. Reference in workflow:
#    env:
#      FIREBASE_SERVICE_ACCOUNT_JSON: ${{ secrets.FIREBASE_SERVICE_ACCOUNT_JSON }}
#      ADMIN_AUTH_SECRET: ${{ secrets.ADMIN_AUTH_SECRET }}

# Vercel Deployment:
# 1. Go to Vercel Dashboard → Project Settings → Environment Variables
# 2. Add each secret with corresponding environment (production)
# 3. Redeploy to apply changes

# Self-hosted Deployment:
# 1. SSH into server
# 2. Create .env file with actual values
# 3. Set file permissions: chmod 600 .env
# 4. Restart application: systemctl restart wstaking

# For Docker deployment:
# 1. Pass via --env-file: docker run --env-file .env wstaking:latest
# 2. Or use docker-compose.yml with environment variables
# 3. Never include .env in Docker image layers
