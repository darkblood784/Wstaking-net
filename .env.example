# ============================================
# WSTAKING ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to public repos

# ============================================
# FRONTEND CONFIG (Client-side)
# ============================================

# Wallet Connect (get from https://cloud.walletconnect.com)
VITE_WALLET_CONNECT_ID=your_wallet_connect_project_id

# Firebase Web Config (client-side, safe to be public)
# Get from: Firebase Console → Project Settings → Web App Config
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Blockchain RPC URLs
# Free options: Infura, Alchemy, QuickNode, or public endpoints
VITE_BASE_RPC=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_BSC_RPC=https://bsc-dataseed.binance.org
VITE_BSC_TESTNET_RPC=https://data-seed-prebsc-1-1.bnbchain.org:8545
VITE_XLAYER_RPC=https://rpc.xlayer.tech
VITE_XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech

# ============================================
# BACKEND CONFIG (Server-side only)
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# IMPORTANT: This is a PRIVATE credential - never commit to public repos
# Set via environment variable or GitHub Secrets in production
# Format: Complete JSON object from Firebase Console → Service Account
FIREBASE_SERVICE_ACCOUNT_JSON=

# Admin Authentication Secret
# Generate with: openssl rand -hex 32
# Keep this secret and secure!
ADMIN_AUTH_SECRET=your_long_random_secret_here_min_32_chars

# ============================================
# SMART CONTRACT ADDRESSES
# ============================================

# BASE Mainnet
BASE_MAINNET_STAKING_ADDRESS=0x

# BASE Sepolia Testnet
BASE_SEPOLIA_STAKING_ADDRESS=0x

# BSC Mainnet
BSC_MAINNET_STAKING_ADDRESS=0x

# BSC Testnet
BSC_TESTNET_STAKING_ADDRESS=0x

# XLayer Mainnet
XLAYER_MAINNET_STAKING_ADDRESS=0x

# ============================================
# EMAIL CONFIGURATION
# ============================================

# SMTP Server (Gmail, Office365, etc.)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your_app_password_or_smtp_password

# Email sender address
EMAIL_FROM=noreply@wstaking.net
EMAIL_FROM_NAME=WStaking

# ============================================
# THIRD-PARTY API KEYS
# ============================================

# Etherscan API (for contract verification, block explorer)
ETHERSCAN_API_KEY=your_etherscan_api_key

# CoinGecko API (for price data)
COINGECKO_API_KEY=your_coingecko_api_key

# Block Explorer APIs (optional)
BSCSCAN_API_KEY=your_bscscan_api_key

# ============================================
# CORS & SECURITY
# ============================================

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# OPTIONAL: BACKEND SIGNING (if needed)
# ============================================

# Only set if backend needs to sign transactions
# NEVER commit actual private keys to public repos
# Use only for development or with hardware wallets in production
# BACKEND_SIGNER_PRIVATE_KEY=

# ============================================
# LOGGING
# ============================================

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
FEATURE_ADMIN_PANEL=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_ANALYTICS=true
